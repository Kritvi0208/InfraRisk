# InfraRiskAI Platform - Environment Configuration Example
# Copy this file to .env and update values for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:pass@localhost:5432/infrarisk

# Database pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ============================================================================
# CACHE & SESSION CONFIGURATION
# ============================================================================

# Redis connection string for caching and sessions
REDIS_URL=redis://localhost:6379/0

# Cache TTL settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=3600
MODEL_CACHE_SIZE=5

# Cache enabled flag
CACHE_ENABLED=True

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================

# World Bank Open Data API
WORLD_BANK_API_KEY=your_world_bank_api_key_here

# IJGlobal subscription API
IJGLOBAL_API_KEY=your_ijglobal_api_key_here

# Refinitiv/Bloomberg market data APIs
REFINITIV_API_KEY=your_refinitiv_api_key_here

# Google Earth Engine API
EARTH_ENGINE_API_KEY=your_earth_engine_api_key_here

# Copernicus Data Space credentials for Sentinel-2
COPERNICUS_USERNAME=your_copernicus_username_here
COPERNICUS_PASSWORD=your_copernicus_password_here

# Bloomberg Terminal API
BLOOMBERG_API_KEY=your_bloomberg_api_key_here

# NOAA Weather API
NOAA_API_KEY=your_noaa_api_key_here

# ============================================================================
# MACHINE LEARNING & MODEL TRACKING
# ============================================================================

# MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://user:pass@localhost:5432/mlflow

# MLflow experiment settings
MLFLOW_EXPERIMENT_NAME=InfraRiskAI
MLFLOW_RUN_TIMEOUT=3600

# Model configuration
BATCH_SIZE=32
NUM_WORKERS=4
MODEL_DEVICE=cuda
INFERENCE_BATCH_SIZE=16

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Debug mode (set to False in production)
DEBUG=False

# Environment type
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Application secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here_minimum_32_characters

# Flask/Streamlit settings
FLASK_ENV=production
STREAMLIT_SERVER_PORT=8501
API_PORT=5000

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,https://app.example.com

# HTTPS/TLS settings
SECURE_ONLY=False
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# CORS settings
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# DATA & FILE PATHS
# ============================================================================

# Raw data directory
DATA_RAW_PATH=./data/raw

# Processed data directory
DATA_PROCESSED_PATH=./data/processed

# Models directory
MODELS_PATH=./models

# Logs directory
LOGS_PATH=./logs

# ============================================================================
# FEATURE ENGINEERING
# ============================================================================

# Feature engineering settings
FEATURE_SELECTION_METHOD=mutual_info
FEATURE_SCALING_METHOD=standardization
MAX_NUM_FEATURES=200

# ============================================================================
# MODEL TRAINING
# ============================================================================

# Training hyperparameters
LEARNING_RATE=0.001
EPOCHS=100
EARLY_STOPPING_PATIENCE=10
VALIDATION_SPLIT=0.2

# Model-specific settings
TFT_HIDDEN_SIZE=128
GNN_NUM_LAYERS=3
PINN_PHYSICS_WEIGHT=0.5
ENSEMBLE_VOTING_METHOD=soft

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# API performance
API_TIMEOUT=300
BATCH_PROCESSING_TIMEOUT=600

# Model inference
INFERENCE_TIMEOUT=60
CACHE_PREDICTIONS=True
ENABLE_PARALLEL_INFERENCE=True

# Database
DATABASE_QUERY_TIMEOUT=30
ENABLE_QUERY_LOGGING=False

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry error tracking (optional)
SENTRY_DSN=

# Datadog monitoring (optional)
DATADOG_API_KEY=

# Log aggregation
LOG_FORMAT=json
LOG_TO_FILE=True
LOG_ROTATION=daily

# ============================================================================
# EMAIL CONFIGURATION (for alerts)
# ============================================================================

# SMTP settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Alert recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=admin@example.com,alerts@example.com

# ============================================================================
# TASK SCHEDULING
# ============================================================================

# Enable background tasks
ENABLE_BACKGROUND_TASKS=True

# Task scheduling intervals (in hours)
MODEL_RETRAINING_INTERVAL=24
DATA_REFRESH_INTERVAL=6
REPORT_GENERATION_INTERVAL=24

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Feature toggles for enabling/disabling components
ENABLE_CLIMATE_ANALYSIS=True
ENABLE_NETWORK_ANALYSIS=True
ENABLE_NLP_ANALYSIS=True
ENABLE_PORTFOLIO_ANALYTICS=True
ENABLE_BACKTESTING=True

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================

# Testing database
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/infrarisk_test

# Mock external APIs (for testing)
USE_MOCK_APIS=False

# Random seed for reproducibility
RANDOM_SEED=42

# ============================================================================
# DOCKER & DEPLOYMENT
# ============================================================================

# Docker settings
DOCKER_REGISTRY=docker.io
IMAGE_NAME=infrarisk
IMAGE_TAG=latest

# Kubernetes settings (if applicable)
K8S_NAMESPACE=default
K8S_REPLICA_COUNT=2

# ============================================================================
# COMPLIANCE & AUDIT
# ============================================================================

# Data retention (in days)
DATA_RETENTION_DAYS=365

# Audit logging
ENABLE_AUDIT_LOG=True
AUDIT_LOG_PATH=./logs/audit.log

# GDPR/Privacy
GDPR_COMPLIANT=True
ANONYMIZE_USER_DATA=False

# ============================================================================
# BUSINESS LOGIC
# ============================================================================

# Risk scoring configuration
RISK_SCORE_MIN=0
RISK_SCORE_MAX=100
CRITICAL_RISK_THRESHOLD=70

# Portfolio analysis
PORTFOLIO_VaR_CONFIDENCE=0.95
PORTFOLIO_STRESS_TEST_SCENARIOS=10

# Notification thresholds
ALERT_ON_RISK_INCREASE_PCT=10
ALERT_ON_NETWORK_CONTAGION=True

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Slack notifications
SLACK_WEBHOOK_URL=

# GitHub integration (if applicable)
GITHUB_TOKEN=

# ============================================================================
# DEVELOPMENT ONLY - REMOVE IN PRODUCTION
# ============================================================================

# Disable SSL verification (UNSAFE - development only)
DISABLE_SSL_VERIFICATION=False

# Mock database mode
USE_MOCK_DATABASE=False

# Verbose output
VERBOSE_LOGGING=False
