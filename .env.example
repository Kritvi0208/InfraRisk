# Application Configuration
APP_NAME=InfraRisk AI
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/infrariskai
REDIS_URL=redis://localhost:6379/0

# Google Earth Engine
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT_JSON=path/to/gee-service-account.json

# Data Sources
WORLD_BANK_API_KEY=your-world-bank-api-key
COMODITY_DATA_SOURCE=world-bank  # or alternative

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=infrariskai-dev

# Feast Feature Store
FEAST_REGISTRY_PATH=data/feast/registry.db
FEAST_ONLINE_STORE_TYPE=redis  # or sqlite

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
MODELS_PATH=models
LOGS_PATH=logs

# Security
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=["http://localhost:3000"]

# Feature Store
FEAST_REDIS_HOST=localhost
FEAST_REDIS_PORT=6379

# DVC Remote (optional)
DVC_REMOTE_URL=s3://your-bucket/dvc-storage
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
