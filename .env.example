# Copy this file to .env before running Docker or local services.

# Application
ENV=production
LOG_LEVEL=INFO
INFRARISK_DATA_PATH=./data/raw

# API service
UVICORN_HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql://infrarisk_user:change-me@db:5432/infrarisk

# PostgreSQL
POSTGRES_DB=infrarisk
POSTGRES_USER=infrarisk_user
POSTGRES_PASSWORD=change-me

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Optional external data sources
WORLD_BANK_API_KEY=
FRED_API_KEY=
GEE_SERVICE_ACCOUNT_JSON=
